{
  "manifest_version": 3,
  "name": "三國萌萌打虛寶序號自動填寫工具",
  "version": "1.3.1",
  "description": "自動批量填寫三國萌萌打虛寶序號表單，簡潔UI與詳細debug日誌",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*/*", "file:///*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
