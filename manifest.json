{
  "manifest_version": 3,
  "name": "三國萌萌打虛寶序號自動填寫工具",
  "version": "2.0.0",
  "description": "直接透過 API 請求批量兌換三國萌萌打虛寶序號",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://coupon.kingdom-story.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
